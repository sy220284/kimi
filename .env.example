# 智能体量化分析系统 - 环境变量配置模板
# 复制本文件为 .env，填写实际值后通过 export $(cat .env | xargs) 加载
# 或在部署环境（Docker/K8s）中直接注入环境变量

# ── AI 模型 API Keys ──────────────────────────────────────────────
# CodeFlow AI (Claude 系列)
CODEFLOW_API_KEY=your_codeflow_api_key_here

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── 数据获取 ──────────────────────────────────────────────────────
TUSHARE_TOKEN=your_tushare_token_here

# ── 东方财富妙想 API ──────────────────────────────────────────────
MX_APIKEY=mkt_JxtvahgMDY2dCy2hI16vy7JkTVXljGuERyNwZOupU2A

# ── 数据库 ────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=quant_analysis
POSTGRES_USER=quant_user
POSTGRES_PASSWORD=your_postgres_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── FastAPI 服务 (B2新增) ─────────────────────────────────────────
# 允许访问 API 的 Key 列表（逗号分隔，空则禁用认证 - 仅限开发环境）
API_KEYS=your_api_key_1,your_api_key_2

# 每客户端每分钟最大请求次数（默认60）
API_RATE_LIMIT=60

# ── AI 子代理 (新增) ──────────────────────────────────────────────
# LLM 调用最大重试次数（默认3）
AI_MAX_RETRIES=3

# LLM 调用基础延迟秒数，指数退避（默认1）
AI_BASE_DELAY=1
